{
  "expo": {
    "name": "Couple Budget",
    "slug": "couple-budget",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "couple-budget",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.couplebudget.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used to secure your account"
      },
      "privacyManifests": {
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366f1"
      },
      "package": "com.couplebudget.app",
      "versionCode": 1
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
